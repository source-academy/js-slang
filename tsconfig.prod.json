{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "skipLibCheck": true
  },
  // Excludes are overwritten when using extends, so we
  // list all the excludes again
  "exclude": [
    "node_modules",
    "dist",
    "sicp_publish",
    "src/**/__tests__/**",
    "src/**/__mocks__/**",
    "src/utils/testing",
    "vitest.config.ts"
  ]
}
